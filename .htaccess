<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

RewriteEngine on
RewriteCond %{HTTP_HOST} ^datamalli\.com$ [OR]
RewriteCond %{HTTP_HOST} ^www\.datamalli\.com$
RewriteRule ^(.*)$ "https\:\/\/www\.datamalli\.fi\/$1" [R=301,L]
RewriteCond %{HTTP_HOST} ^datamalli\.com\.inflaatiokorjaus\.fi$ [OR]
RewriteCond %{HTTP_HOST} ^www\.datamalli\.com\.inflaatiokorjaus\.fi$
RewriteRule ^(.*)$ "https\:\/\/www\.datamalli\.fi\/$1" [R=301,L]
RewriteCond %{HTTP_HOST} ^datamalli\.fi$ [OR]
RewriteCond %{HTTP_HOST} ^www\.datamalli\.fi$
RewriteRule ^(.*)$ "https\:\/\/www\.datamalli\.fi\/$1" [R=301,L]
RewriteCond %{HTTP_HOST} ^datamalli\.fi\.inflaatiokorjaus\.fi$ [OR]
RewriteCond %{HTTP_HOST} ^www\.datamalli\.fi\.inflaatiokorjaus\.fi$
RewriteRule ^(.*)$ "https\:\/\/www\.datamalli\.fi\/$1" [R=301,L]
