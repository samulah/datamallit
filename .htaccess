# datamalli.fi — LiteSpeed / Apache -konfiguraatio

# ── HTTPS-ohjaukset ────────────────────────────────────────────────────────────
# (Palvelin hoitaa nämä jo — pidetään tässä dokumentaationa / varmuuden vuoksi)
RewriteEngine On

# http → https
RewriteCond %{HTTPS} off
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# apex → www (https)
RewriteCond %{HTTPS} on
RewriteCond %{HTTP_HOST} ^datamalli\.fi$ [NC]
RewriteRule ^ https://www.datamalli.fi%{REQUEST_URI} [R=301,L]

# ── Tietoturvaotsikot ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # HSTS: pakota HTTPS 1 vuodeksi (myös alidomainit)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"

  # Estä MIME-sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Viittaajatieto: lähetetään täysi URL samalta sivustolta, vain origin muualle
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Estä clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"

  # Poista palvelimen versioinfo
  Header always unset X-Powered-By
  Header always unset Server

  # Content Security Policy — sallii vain omat resurssit + Google Fonts (käytössä?)
  # inline-skriptit sallittu (sivusto käyttää <script>-tageja suoraan HTML:ssä)
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"

  # Poista käyttöön ottamattomat selainominaisuudet
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
</IfModule>

# ── Pakkaus (Brotli/gzip) ──────────────────────────────────────────────────────
# LiteSpeed hoitaa Brotlin automaattisesti — tämä on varmuuden vuoksi gzip-fallback
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# ── Välimuisti staattisille resursseille ───────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
